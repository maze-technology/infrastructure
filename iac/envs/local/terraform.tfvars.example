# Local environment — copy to terraform.tfvars and customize
# DO NOT commit terraform.tfvars with secrets

# ── Cluster domain ───────────────────────────────────────────────────────────
# All services live under this domain. Point every hostname to your VPS IP in /etc/hosts.
cluster_domain    = "maze.local"
cluster_public_ip = "203.0.113.10" # Your VPS public IP (generates /etc/hosts via tofu output)

# ── Bootstrap admin (configure BEFORE first deploy) ──────────────────────────
#
# Two admin levels:
#   1. Keycloak master admin — manages Keycloak itself (/admin console)
#   2. Platform admin — your root user in the maze realm (SSO + VPN)
#
# WireGuard peer config is retrieved via kubectl — VPN is not needed for bootstrap.
# auth.maze.local is VPN-restricted (same as production).

# keycloak_admin_username = "admin"
# keycloak_admin_password = "YourKeycloakMasterPassword123!"

# bootstrap_admin = {
#   username = "admin"
#   password = "YourPlatformAdminPassword123!"
#   email    = "admin@maze.tech"
# }

# WireGuard peer name (defaults to bootstrap_admin.username)
# wireguard_peers = "admin"

# Additional users (optional)
# bootstrap_users = [
#   {
#     username = "developer"
#     password = "DevPassword123!"
#     email    = "dev@maze.tech"
#     groups   = ["engineers", "vpn-users"]
#   }
# ]

# ── Cluster backup (Velero + Kopia → local RGW) ─────────────────────────────
# Encrypted PVC backups + rclone crypt mirror of GitLab/Loki RGW buckets.
# Generate once and store offline:  openssl rand -base64 32
# backup_enabled              = true
# backup_encryption_password  = "REPLACE-WITH-openssl-rand-base64-32"
# backup_schedule_cron        = "0 2 * * *"   # Velero daily 02:00 UTC
# backup_ttl                  = "168h"        # retain 7 days
# backup_s3_bucket            = "cluster-backup-local"
