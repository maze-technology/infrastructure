# Production — copy to terraform.tfvars and fill in values
# DO NOT commit terraform.tfvars with secrets

# ── Cluster domain ───────────────────────────────────────────────────────────
# All services: auth.<domain>, scm.<domain>, vpn.<domain>, etc.
cluster_domain = "maze.tech"

# ── Kubernetes access ────────────────────────────────────────────────────────
kubeconfig_context = "production"

# ── Bootstrap admin (configure BEFORE first deploy) ──────────────────────────
# keycloak_admin_username = "admin"
# keycloak_admin_password = "..."
# bootstrap_admin = {
#   username = "admin"
#   password = "..."
#   email    = "admin@maze.tech"
# }

# ── WireGuard ────────────────────────────────────────────────────────────────
# Defaults to vpn.<cluster_domain> — ensure DNS points to your public IP
# wireguard_server_url = "vpn.prod.maze.tech"

# ── Rook-Ceph storage ────────────────────────────────────────────────────────
# storage_nodes = [
#   { name = "bm-node-01", devices = ["/dev/sdb"] },
#   { name = "bm-node-02", devices = ["/dev/sdb"] },
#   { name = "bm-node-03", devices = ["/dev/sdb"] },
# ]

# ── TLS ──────────────────────────────────────────────────────────────────────
# letsencrypt_email = "admin@maze.tech"

# ── Keycloak database (OVH managed PostgreSQL) ───────────────────────────────
# keycloak_postgresql_host     = "postgresql-xxxxx.database.cloud.ovh.net"
# keycloak_postgresql_password = "..."

# ── GitLab databases (OVH managed) ───────────────────────────────────────────
# gitlab_postgresql_host     = "postgresql-xxxxx.database.cloud.ovh.net"
# gitlab_postgresql_password = "..."

# ── Vault ────────────────────────────────────────────────────────────────────
# vault_token = "..."

# ── Cluster backup (Velero + Kopia + RGW mirror → OVH Object Storage) ────────
# On by default. OpenTofu creates the OVH bucket and enables versioning.
# Required secrets in terraform.tfvars:
#   openssl rand -base64 32   # → backup_encryption_password (store offline)
#
# External resources (e.g. OVH managed PostgreSQL for GitLab/Keycloak) are NOT
# backed up by this stack — the person running the infrastructure must handle those.
backup_enabled             = true
backup_s3_bucket           = "maze-cluster-backup-production"
backup_s3_endpoint         = "https://s3.gra.io.cloud.ovh.net"
backup_s3_region           = "gra"
# backup_s3_access_key       = "..."
# backup_s3_secret_key       = "..."
# backup_encryption_password = "REPLACE-WITH-openssl-rand-base64-32"
# backup_schedule_cron       = "0 2 * * *"
# backup_ttl                 = "720h"   # retain 30 days
# backup_object_sync_enabled = true
# backup_object_sync_schedule_cron = "30 2 * * *"
